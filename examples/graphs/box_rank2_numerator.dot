digraph box_rank2_numerator {
  graph [
    label="box_rank2_numerator",
    num="k(mu)*k(mu)+3*k(nu)*p1(nu)*k(rho)*p2(rho)",
    loop_momenta="k",
    external_momenta="p1,p2,p3",
    lorentz_indices="mu,nu,rho",
    propagators="k**2;(k+p1)**2;(k+p1+p2)**2;(k+p1+p2+p3)**2"
  ];
  ext1 [style=invis];
  ext2 [style=invis];
  ext3 [style=invis];
  ext4 [style=invis];
  v1; v2; v3; v4;

  v1 -> ext1 [id=0, name="p1", mom="p1"];
  v2 -> ext2 [id=1, name="p2", mom="p2"];
  v3 -> ext3 [id=2, name="p3", mom="p3"];
  v4 -> ext4 [id=3, name="p4", mom="p4"];

  v1 -> v2 [id=4, name="e0", mass="0"];
  v2 -> v3 [id=5, name="e1", mass="0"];
  v3 -> v4 [id=6, name="e2", mass="0"];
  v4 -> v1 [id=7, name="e3", mass="0"];
}
