digraph box {
  graph [label="box"];
  ext1 [style=invis];
  ext2 [style=invis];
  ext3 [style=invis];
  ext4 [style=invis];
  v1; v2; v3; v4;

  v1 -> ext1 [id=0, name="p1", mom="p1"];
  v2 -> ext2 [id=1, name="p2", mom="p2"];
  v3 -> ext3 [id=2, name="p3", mom="p3"];
  v4 -> ext4 [id=3, name="p4", mom="p4"];

  v1 -> v2 [id=4, name="e0", mass="mt"];
  v2 -> v3 [id=5, name="e1", mass="mt"];
  v3 -> v4 [id=6, name="e2", mass="mt"];
  v4 -> v1 [id=7, name="e3", mass="mt"];
}
